# Get these from your Neon dashboard at https://neon.tech
# DATABASE_URL = pooled connection string (used by the app at runtime)
# DIRECT_URL   = direct connection string (used by prisma migrate/db push)

DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

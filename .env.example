# Turso (libSQL/SQLite) — primary database. Sign up at turso.tech.
# Get DATABASE_URL from: turso db show <name> --url
# Get TOKEN from:        turso db tokens create <name>
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN="eyJ..."

# Local SQLite file used by `prisma generate` for typegen only.
# Runtime queries use the libSQL adapter; this URL is never opened at runtime.
DATABASE_URL="file:./prisma/dev.db"
